# ============================================
# data-crawler-platform - Root .gitignore
# ============================================

# ─── Node.js ────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Next.js ────────────────────────────────
.next/
out/

# ─── Python ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl

# ─── Virtual Environments ───────────────────
venv/
.venv/
env/
.env/

# ─── Environment Variables ──────────────────
.env
.env.local
.env.*.local

# ─── PyInstaller ────────────────────────────
crawler-tool-gui/build/
crawler-tool-gui/dist/
*.spec

# ─── Playwright / Browser Data ──────────────
insta_session/
twitter_session/
tiktok_session/
*_session/

# ─── IDE ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Logs ───────────────────────────────────
logs/
*.log

# ─── OS ─────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Misc ───────────────────────────────────
*.bak
*.tmp
*.temp
